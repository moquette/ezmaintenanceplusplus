<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
	<section id="script.ezmaintenanceplusplus">
		<category id="maintenance" label="30000">
			<group id="1">
				<setting id="notify_mode" type="boolean" label="30030">
					<level>0</level>
					<default>false</default>
					<control type="toggle" />
				</setting>
			</group>
			<group id="2" label="30010">
				<setting id="startup.cache" type="boolean" label="30031">
					<level>0</level>
					<default>true</default>
					<control type="toggle" />
				</setting>
				<setting id="autoCleanDays" type="integer" label="30032">
					<level>0</level>
					<default>0</default>
					<constraints>
						<minimum>0</minimum>
						<step>1</step>
						<maximum>365</maximum>
					</constraints>
					<control type="slider" format="integer" />
				</setting>
				<setting id="autoCleanHour" type="integer" parent="autoCleanDays" label="30033">
					<level>0</level>
					<default>4</default>
					<constraints>
						<minimum>0</minimum>
						<step>1</step>
						<maximum>23</maximum>
					</constraints>
					<dependencies>
						<dependency type="enable" setting="autoCleanDays" operator="!is">0</dependency>
					</dependencies>
					<control type="slider" format="integer" />
				</setting>
			</group>
			<group id="3" label="30011">
				<setting id="filesize_alert" type="integer" label="30034">
					<level>0</level>
					<default>200</default>
					<constraints>
						<minimum>25</minimum>
						<step>1</step>
						<maximum>500</maximum>
					</constraints>
					<control type="slider" format="integer" />
				</setting>
				<setting id="packagenumbers_alert" type="integer" label="30035">
					<level>0</level>
					<default>50</default>
					<constraints>
						<minimum>5</minimum>
						<step>1</step>
						<maximum>200</maximum>
					</constraints>
					<control type="slider" format="integer" />
				</setting>
			</group>
			<group id="4" label="30012">
