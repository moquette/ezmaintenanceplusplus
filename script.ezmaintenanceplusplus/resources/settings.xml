<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings version="1">
	<section id="script.ezmaintenanceplusplus">
		<category id="maintenance" label="30000">
			<group id="1">
				<setting id="notify_mode" type="boolean" label="30030">
					<level>0</level>
					<default>false</default>
					<control type="toggle" />
				</setting>
			</group>
			<group id="2" label="30010">
				<setting id="startup.cache" type="boolean" label="30031">
					<level>0</level>
					<default>true</default>
					<control type="toggle" />
				</setting>
				<setting id="autoCleanDays" type="integer" label="30032">
					<level>0</level>
					<default>0</default>
					<constraints>
						<minimum>0</minimum>
						<step>1</step>
						<maximum>365</maximum>
					</constraints>
					<control type="slider" format="integer" />
				</setting>
				<setting id="autoCleanHour" type="integer" parent="autoCleanDays" label="30033">
					<level>0</level>
					<default>4</default>
					<constraints>
						<minimum>0</minimum>
						<step>1</step>
						<maximum>23</maximum>
					</constraints>
					<dependencies>
						<dependency type="enable" setting="autoCleanDays" operator="!is">0</dependency>
					</dependencies>
					<control type="slider" format="integer" />
				</setting>
			</group>
			<group id="3" label="30011">
				<setting id="filesize_alert" type="integer" label="30034">
					<level>0</level>
					<default>200</default>
					<constraints>
						<minimum>25</minimum>
						<step>1</step>
						<maximum>500</maximum>
					</constraints>
					<control type="slider" format="integer" />
				</setting>
				<setting id="packagenumbers_alert" type="integer" label="30035">
					<level>0</level>
					<default>50</default>
					<constraints>
						<minimum>5</minimum>
						<step>1</step>
						<maximum>200</maximum>
					</constraints>
					<control type="slider" format="integer" />
				</setting>
			</group>
			<group id="4" label="30012">
				<setting id="filesizethumb_alert" type="integer" label="30036">
					<level>0</level>
					<default>500</default>
					<constraints>
						<minimum>50</minimum>
						<step>1</step>
						<maximum>2000</maximum>
					</constraints>
					<control type="slider" format="integer" />
				</setting>
			</group>
		</category>

		<category id="backup_restore" label="30002">
			<group id="1">
				<setting id="BackupFixSpecialHome" type="boolean" label="30050">
					<level>0</level>
					<default>false</default>
					<control type="toggle" />
				</setting>
				<setting id="destination" type="integer" label="30051">
					<level>0</level>
					<default>0</default>
					<constraints>
						<options>
							<option label="30052">0</option>
							<option label="30053">1</option>
							<option label="30054">2</option>
						</options>
					</constraints>
					<control type="spinner" format="string" />
				</setting>
				<setting id="backup.keep" type="integer" label="30055">
					<level>0</level>
					<default>5</default>
					<constraints>
						<minimum>0</minimum>
						<step>1</step>
						<maximum>50</maximum>
					</constraints>
					<control type="slider" format="integer" />
				</setting>
				<setting id="download.path" type="path" label="30056">
					<level>0</level>
					<default></default>
					<constraints>
						<allowempty>true</allowempty>
						<sources>
							<source>files</source>
						</sources>
					</constraints>
					<dependencies>
						<dependency type="visible" setting="destination" operator="!is">2</dependency>
					</dependencies>
					<control type="button" format="path">
						<heading>30056</heading>
					</control>
				</setting>
				<setting id="restore.path" type="path" label="30057">
					<level>0</level>
					<default></default>
					<constraints>
						<allowempty>true</allowempty>
						<sources>
							<source>files</source>
						</sources>
					</constraints>
					<dependencies>
						<dependency type="visible" setting="destination" operator="!is">2</dependency>
					</dependencies>
					<control type="button" format="path">
						<heading>30057</heading>
					</control>
				</setting>
				<setting id="dropbox_signin" type="action" label="30058">
					<level>0</level>
					<default></default>
					<dependencies>
						<dependency type="visible" setting="destination">2</dependency>
					</dependencies>
					<control type="button" format="action">
						<data>RunScript(script.ezmaintenanceplusplus,authorize)</data>
					</control>
				</setting>
				<setting id="dropbox_key" type="string" label="30059">
					<level>0</level>
					<default></default>
					<constraints>
						<allowempty>true</allowempty>
					</constraints>
					<dependencies>
						<dependency type="visible" setting="destination">2</dependency>
					</dependencies>
					<control type="edit" format="string">
						<heading>30059</heading>
					</control>
				</setting>
				<setting id="dropbox_secret" type="string" label="30060">
					<level>0</level>
					<default></default>
					<constraints>
						<allowempty>true</allowempty>
					</constraints>
					<dependencies>
						<dependency type="visible" setting="destination">2</dependency>
					</dependencies>
					<control type="edit" format="string">
						<heading>30060</heading>
					</control>
				</setting>
				<setting id="dropbox_refresh_token" type="string">
					<level>0</level>
					<default></default>
					<constraints>
						<allowempty>true</allowempty>
					</constraints>
					<visible>false</visible>
					<control type="edit" format="string" />
				</setting>
			</group>
		</category>
		<category id="freshstart" label="30003">
			<group id="1">
				<setting id="freshstart.keep_sources" type="boolean" label="30061">
					<level>0</level>
					<default>false</default>
					<control type="toggle" />
				</setting>
				<setting id="freshstart.keep_repos" type="boolean" label="30062">
					<level>0</level>
					<default>false</default>
					<control type="toggle" />
				</setting>
			</group>
		</category>
	</section>
</settings>
