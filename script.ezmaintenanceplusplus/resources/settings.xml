<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
	<category label="Maintenance">
		<setting id="notify_mode" type="bool" label="Show Stats at Startup" default="false" />
                <setting type="lsep" label="AutoClean" />
		<setting id="startup.cache" type="bool" label="AutoClean Cache at Startup" default="true" />
		<setting id="autoCleanDays" type="slider" label="AutoClean Cache Every Number of Days (0 is Not)" default="0" range="0,365" option="int" />
		<setting id="autoCleanHour" type="slider" label="AutoClean Cache at Hour (0-12 = AM / 12-23 = PM)" default="4" range="0,23" option="int" enable="!eq(-1,0)" subsetting="true" />
                <setting type="lsep" label="Package Folder Limits" />
		<setting id="filesize_alert" type="slider" label="Max Total Files Size (MB)" default="200" range="25,500" option="int" />
		<setting id="packagenumbers_alert" type="slider" label="Max Number of Zip Files" default="50" range="5,200" option="int" />
		<setting type="lsep" label="Thumbnails Folder Limits" />
		<setting id="filesizethumb_alert" type="slider" label="Max Total Files Size (MB)" default="500" range="50,2000" option="int" />
	</category>

	<category label="One-Tap Restore">
		<setting type="lsep" label="Manage your one-tap backups from the ONE-TAP RESTORE menu (open the add-on). This tab just stores the pins." />
		<setting id="pin1_name" type="text" default="" visible="false" />
		<setting id="pin1_kind" type="text" default="" visible="false" />
		<setting id="pin1_src" type="text" default="" visible="false" />
		<setting id="pin1_type" type="text" default="" visible="false" />
		<setting id="pin1_meta" type="text" default="" visible="false" />
		<setting id="pin2_name" type="text" default="" visible="false" />
		<setting id="pin2_kind" type="text" default="" visible="false" />
		<setting id="pin2_src" type="text" default="" visible="false" />
		<setting id="pin2_type" type="text" default="" visible="false" />
		<setting id="pin2_meta" type="text" default="" visible="false" />
		<setting id="pin3_name" type="text" default="" visible="false" />
		<setting id="pin3_kind" type="text" default="" visible="false" />
		<setting id="pin3_src" type="text" default="" visible="false" />
		<setting id="pin3_type" type="text" default="" visible="false" />
		<setting id="pin3_meta" type="text" default="" visible="false" />
		<setting id="pin4_name" type="text" default="" visible="false" />
		<setting id="pin4_kind" type="text" default="" visible="false" />
		<setting id="pin4_src" type="text" default="" visible="false" />
		<setting id="pin4_type" type="text" default="" visible="false" />
		<setting id="pin4_meta" type="text" default="" visible="false" />
		<setting id="pin5_name" type="text" default="" visible="false" />
		<setting id="pin5_kind" type="text" default="" visible="false" />
		<setting id="pin5_src" type="text" default="" visible="false" />
		<setting id="pin5_type" type="text" default="" visible="false" />
		<setting id="pin5_meta" type="text" default="" visible="false" />
		<setting id="pin6_name" type="text" default="" visible="false" />
		<setting id="pin6_kind" type="text" default="" visible="false" />
		<setting id="pin6_src" type="text" default="" visible="false" />
		<setting id="pin6_type" type="text" default="" visible="false" />
		<setting id="pin6_meta" type="text" default="" visible="false" />
	</category>
	<category label="Backup/Restore">
		<setting id="BackupFixSpecialHome" type="bool" label="Replace home folder in xml files with special://home" default="false" />
		<setting id="destination" type="enum" label="Destination" values="Local|Network (SMB/NFS)|Dropbox" default="0" />
		<setting id="backup.keep" type="slider" label="Keep how many backups (0 = keep all)" default="5" range="0,50" option="int" />
		<setting id="download.path" type="folder" label="Backup Location" visible="!eq(-2,2)" />
		<setting id="restore.path" type="folder" label="Restore from Zip Location (folder)" visible="!eq(-3,2)" />
		<setting id="dropbox_signin" type="action" label="Sign in to Dropbox" action="RunScript(script.ezmaintenanceplusplus,authorize)" option="close" visible="eq(-4,2)" />
		<setting id="dropbox_key" type="text" label="Dropbox App key (advanced - only if not signing in normally)" default="" visible="eq(-5,2)" />
		<setting id="dropbox_secret" type="text" label="Dropbox App secret (advanced)" default="" visible="eq(-6,2)" />
		<setting id="dropbox_refresh_token" type="text" label="Dropbox refresh token" default="" visible="false" />
    </category>
</settings>